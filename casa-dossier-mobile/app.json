{
  "expo": {
    "name": "Casa Dossier",
    "slug": "casa-dossier",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#020617",
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Casa Dossier to scan technical specification plates."
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.casadossier.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.casadossier.app",
      "adaptiveIcon": {
        "backgroundColor": "#020617"
      }
    }
  }
}